{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "HIDS Configuration Schema",
  "description": "JSON Schema for validating config.json.",
  "properties": {
    "paths": {
      "type": "object",
      "description": "Paths to external executables.",
      "properties": {
        "tshark": {
          "type": "string",
          "description": "Absolute path to tshark.exe."
        }
      },
      "required": [
        "tshark"
      ]
    },
    "settings": {
      "type": "object",
      "description": "General system settings.",
      "properties": {
        "scan_duration_sec": {
          "type": "integer",
          "minimum": 5,
          "description": "Network scan duration in seconds."
        },
        "network_interface": {
          "type": "string",
          "description": "Name of the active network interface (e.g. 'Wi-Fi', 'Ethernet')."
        }
      },
      "required": [
        "scan_duration_sec",
        "network_interface"
      ]
    },
    "whitelists": {
      "type": "object",
      "description": "Trusted entities that are never flagged.",
      "properties": {
        "trusted_ips": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of trusted IP addresses (e.g. DNS servers, home router)."
        },
        "trusted_authors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Trusted Authenticode certificate publishers."
        }
      }
    },
    "blacklists": {
      "type": "object",
      "description": "Suspicious or forbidden entities.",
      "properties": {
        "suspicious_ports": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "description": "Ports commonly used by malware/RATs."
        },
        "suspicious_tlds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "High-risk domain TLDs (e.g. .xyz, .top, .tk)."
        }
      }
    }
  },
  "required": [
    "paths",
    "settings",
    "whitelists",
    "blacklists"
  ]
}