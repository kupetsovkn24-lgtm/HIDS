{
    "_comment": "Copy this file to config/config.json and adjust the values for your system.",
    "paths": {
        "tshark": "C:\\Program Files\\Wireshark\\tshark.exe"
    },
    "settings": {
        "network_interface": "Wi-Fi",
        "days_to_keep_logs": 7,
        "scan_duration_sec": 10,
        "strict_mode_process_ports": true
    },
    "whitelists": {
        "trusted_ips": [
            "8.8.8.8",
            "8.8.4.4",
            "1.1.1.1",
            "1.0.0.1"
        ],
        "trusted_dns_over_https_domains": [
            "dns.google",
            "cloudflare-dns.com"
        ],
        "trusted_domain_suffixes": [
            ".googlevideo.com",
            ".cloudfront.net",
            ".akamaized.net"
        ],
        "trusted_exact_domains": [
            "youtube.com",
            "office365.com",
            "microsoft.com",
            "github.com"
        ],
        "process_trusted_ports": {
            "chrome.exe": [
                80,
                443,
                5228
            ],
            "firefox.exe": [
                80,
                443
            ],
            "msedge.exe": [
                80,
                443
            ],
            "telegram.exe": [
                80,
                443,
                5222
            ],
            "signal.exe": [
                80,
                443,
                4433,
                8443
            ],
            "code.exe": [
                80,
                443,
                3000,
                5173
            ]
        },
        "trusted_authors": [
            "Microsoft",
            "Microsoft Corporation",
            "Google LLC",
            "Intel Corporation",
            "NVIDIA Corporation"
        ]
    },
    "blacklists": {
        "suspicious_paths": [
            "C:\\Temp",
            "C:\\Windows\\Temp",
            "C:\\Users\\Public",
            "C:\\Users\\%USERNAME%\\AppData\\Local\\Temp",
            "C:\\Users\\%USERNAME%\\AppData\\Roaming\\Microsoft",
            "C:\\Users\\%USERNAME%\\Downloads"
        ],
        "suspicious_ports": [
            1337,
            4444,
            5555,
            6667,
            8888,
            9999,
            3389,
            5900,
            8081
        ],
        "suspicious_tlds": [
            ".xyz",
            ".top",
            ".club",
            ".tk",
            ".pw",
            ".su",
            ".cm",
            ".cf",
            ".ga",
            ".ml",
            ".work",
            ".link",
            ".click",
            ".vip",
            ".loan",
            ".win"
        ]
    },
    "registry": {
        "autorun_paths": [
            [
                "HKCU",
                "Software\\Microsoft\\Windows\\CurrentVersion\\Run"
            ],
            [
                "HKCU",
                "Software\\Microsoft\\Windows\\CurrentVersion\\RunOnce"
            ],
            [
                "HKLM",
                "Software\\Microsoft\\Windows\\CurrentVersion\\Run"
            ],
            [
                "HKLM",
                "Software\\Microsoft\\Windows\\CurrentVersion\\RunOnce"
            ],
            [
                "HKLM",
                "Software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Run"
            ]
        ],
        "autorun_extended_paths": [
            [
                "HKLM",
                "Software\\Microsoft\\Windows NT\\CurrentVersion\\Winlogon"
            ],
            [
                "HKCU",
                "Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\StartupApproved\\Run"
            ],
            [
                "HKLM",
                "Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\Run"
            ]
        ]
    },
    "filesystem": {
        "ignore_extensions": [
            ".txt",
            ".log",
            ".ini",
            ".cfg",
            ".json",
            ".md"
        ],
        "suspicious_extensions": [
            ".exe",
            ".dll",
            ".bat",
            ".vbs",
            ".js",
            ".scr",
            ".ps1",
            ".cmd",
            ".wsf"
        ]
    },
    "network_detection": {
        "dga_entropy_threshold": 4.0,
        "dns_tunnel_length_threshold": 60
    },
    "tasks": {
        "suspicious_task_keywords": [
            "powershell",
            "pwsh",
            "cmd.exe /c",
            "base64",
            "invoke-expression",
            "iex",
            "update",
            "helper",
            "service",
            "backup",
            "remote",
            "payload",
            "agent"
        ]
    },
    "correlation_rules": {
        "suspicious_parent": {
            "office_procs": [
                "winword.exe",
                "excel.exe",
                "powerpnt.exe",
                "outlook.exe"
            ],
            "shell_procs": [
                "cmd.exe",
                "powershell.exe",
                "pwsh.exe",
                "wscript.exe",
                "cscript.exe"
            ],
            "expected_parents": {
                "svchost.exe": "services.exe"
            }
        },
        "lolbas_patterns": {
            "certutil.exe": [
                "-urlcache.*http",
                "-encode"
            ],
            "bitsadmin.exe": [
                "/transfer",
                "/create"
            ],
            "regsvr32.exe": [
                "/i:http",
                "/i:ftp"
            ],
            "rundll32.exe": [
                "javascript:",
                "shell32.dll.*control_rundll"
            ],
            "mshta.exe": [
                "http:",
                "vbscript:"
            ]
        }
    }
}